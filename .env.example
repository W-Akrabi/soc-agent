# Required
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Threat intelligence — optional, tools degrade gracefully without them
NVD_API_KEY=your_nvd_api_key_here
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# Optional — defaults shown
SOC_MODEL=claude-sonnet-4-6
SOC_DB_PATH=./soc_cases.db
SOC_REPORTS_DIR=./reports
SOC_COMMANDER_TIMEOUT=300
SOC_AGENT_TIMEOUT=120
SOC_AUTO_REMEDIATE=false
SOC_LOG_LEVEL=INFO
SOC_API_TOKEN=replace_with_a_long_random_token
SOC_API_APPROVER_TOKEN=replace_with_a_separate_long_random_token
