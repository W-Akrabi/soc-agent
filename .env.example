# Copy this file to .env and change only what you need.
# Dry-run mode works without any API keys:
#   python3 main.py investigate simulated --dry-run

# Model provider
SOC_PROVIDER=anthropic
SOC_MODEL=claude-sonnet-4-6

# Provider credentials and endpoints
# Choose one provider path:
# 1. Anthropic: set SOC_PROVIDER=anthropic and ANTHROPIC_API_KEY
# 2. OpenAI-compatible: set SOC_PROVIDER=openai, OPENAI_API_KEY, OPENAI_BASE_URL, and SOC_MODEL
# 3. Ollama: set SOC_PROVIDER=ollama, OLLAMA_BASE_URL, and SOC_MODEL
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Common live-model examples:
# Anthropic:
#   SOC_PROVIDER=anthropic
#   SOC_MODEL=claude-sonnet-4-6
# OpenAI-compatible:
#   SOC_PROVIDER=openai
#   SOC_MODEL=gpt-4.1
#   OPENAI_BASE_URL=https://api.openai.com/v1
# Ollama:
#   SOC_PROVIDER=ollama
#   SOC_MODEL=qwen3:8b
#   OLLAMA_BASE_URL=http://127.0.0.1:11434
#   Start Ollama.app or run `ollama serve`, then verify with:
#   curl http://127.0.0.1:11434/api/tags

# Core runtime paths
SOC_DB_PATH=./soc_cases.db
SOC_REPORTS_DIR=./reports
SOC_EVENT_LOG_DIR=./event_logs

# Timeouts and logging
SOC_COMMANDER_TIMEOUT=300
SOC_AGENT_TIMEOUT=120
SOC_LOG_LEVEL=INFO

# Investigation behavior
SOC_AUTO_REMEDIATE=false
SOC_ENABLE_MEMORY=true
SOC_MEMORY_DB_PATH=./soc_memory.db
SOC_MEMORY_CONTEXT_LIMIT=3
SOC_ENABLE_APPROVAL_QUEUE=true
SOC_APPROVAL_DB_PATH=./soc_approvals.db

# API mode
SOC_API_HOST=127.0.0.1
SOC_API_PORT=8080
SOC_API_TOKEN=replace_with_a_long_random_token
SOC_API_APPROVER_TOKEN=replace_with_a_separate_long_random_token
SOC_ENABLE_METRICS=true
SOC_APPROVER_IDENTITIES=

# Worker mode
SOC_WORKER_MODE=local
SOC_WORKER_DB_PATH=./soc_workers.db
SOC_WORKER_POLL_INTERVAL=1.0
SOC_WORKER_LEASE_TIMEOUT=600
SOC_WORKER_HEARTBEAT_INTERVAL=15.0

# Storage backends
SOC_STORAGE_BACKEND=sqlite
SOC_POSTGRES_DSN=
SOC_POSTGRES_SCHEMA=public
SOC_VECTOR_DIMENSIONS=1536

# Control-plane storage
SOC_CONTROLPLANE_BACKEND=sqlite
SOC_CONTROLPLANE_POSTGRES_DSN=
SOC_CONTROLPLANE_POSTGRES_SCHEMA=soc_control

# Integrations
SOC_ENABLED_INTEGRATIONS=
SOC_FIXTURE_MODE=off
SOC_FIXTURE_DIR=
SOC_ALLOW_LIVE_INTEGRATIONS=false
SOC_ALLOW_WRITE_INTEGRATIONS=false
SOC_ALLOW_INTEGRATION_EXECUTION=false
SOC_INTEGRATION_TIMEOUT=30
SOC_ALLOWED_ACTIONS=

# Optional threat intelligence credentials
NVD_API_KEY=
ABUSEIPDB_API_KEY=
VIRUSTOTAL_API_KEY=
